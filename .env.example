# Database connection (required)
# Local Docker Compose: postgresql://happyrobot:happyrobot@db:5432/happyrobotai
# Local dev (no Docker): postgresql://happyrobot:happyrobot@localhost:5432/happyrobotai
# Railway: automatically set when you add a Postgres plugin
DATABASE_URL=postgresql://happyrobot:happyrobot@localhost:5432/happyrobotai

# API key for authenticating webhook and agent API requests (required)
# Change this to a strong secret in production
API_KEY=your-secret-api-key

# Dashboard password for Basic Auth (recommended in production)
# Username is "admin", password is this value
# If not set, the dashboard is accessible without authentication
DASHBOARD_PASSWORD=

# HappyRobot webcall iframe URL (required for Webcall page)
# This differs per environment (dev, staging, production)
WEBCALL_URL=https://platform.happyrobot.ai/deployments/YOUR_DEPLOYMENT_ID/YOUR_AGENT_ID

# FMCSA Web Key for carrier verification (optional)
# Get one at https://mobile.fmcsa.dot.gov/QCDevsite/
FMCSA_WEB_KEY=
